#------------------------------------------------------------------------------------------------------------------------------------------------------------------

parted /dev/sda mklabel msdos
cfdisk /dev/sda

# sda 1    - Swap
# sda 2    - Boot
# sda 3    - ALL Disk

# Diskin tamamını sil ve MS-DOS tablosu oluştur
parted $DISK --script mklabel msdos
# Swap bölümü 8GB (0 – 8 GB)
parted $DISK --script mkpart primary linux-swap 0GB 8GB
# Boot bölümü 1GB (8 – 9 GB)
parted $DISK --script mkpart primary ext4 8GB 9GB
parted $DISK --script set 2 boot on
# Root / All disk bölümü (9 GB – disk sonu)
parted $DISK --script mkpart primary ext4 9GB 100%

# Bölümleri kontrol
parted $DISK print

# disk part
mkswap /dev/sda1
swapon /dev/sda1
mkfs.ext4 /dev/sda2
mkfs.ext4 /dev/sda3

# mount disk part
mount /dev/sda3 /mnt         # Mount root
mkdir /mnt/boot              # Create /boot directory
mount /dev/sda2 /mnt/boot    # Mount /boot

# last need
pacstrap /mnt base base base-devel grub nano
genfstab -U /mnt >> /mnt/etc/fstab
arch-chroot /mnt

#------------------------------------------------------------------------------------------------------------------------------------------------------------------

vpnbook + openvpn

#------------------------------------------------------------------------------------------------------------------------------------------------------------------
# network manager
pacman -Sy networkmanager
systemctl enable NetworkManager
#------------------------------------------------------------------------------------------------------------------------------------------------------------------


#------------------------------------------------------------------------------------------------------------------------------------------------------------------
ln -sf /usr/share/zoneinfo/Europe/Istanbul /etc/localtime
hwclock --systohc

echo "ThisIsMyKingdomCOME" > /etc/hostname
useradd -m -G wheel -s /bin/bash archkubi
nano /etc/sudoers
passwd archkubi
passwd root
