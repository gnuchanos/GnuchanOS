#------------------------------------------------------------------------------------------------------------------------------------------------------------------

parted /dev/sda mklabel msdos
cfdisk /dev/sda

# sda 1    - Swap
# sda 2    - Boot
# sda 3    - ALL Disk

# Bölümleri kontrol
parted $DISK print

# disk part
mkswap /dev/sda1
swapon /dev/sda1
mkfs.ext4 /dev/sda2
mkfs.ext4 /dev/sda3

# mount disk part
mount /dev/sda3 /mnt         # Mount root
mkdir /mnt/boot              # Create /boot directory
mount /dev/sda2 /mnt/boot    # Mount /boot

# last need
pacstrap /mnt base base base-devel grub nano linux linux-firmware linux-headers
genfstab -U /mnt >> /mnt/etc/fstab
arch-chroot /mnt

#------------------------------------------------------------------------------------------------------------------------------------------------------------------

vpnbook + openvpn

#------------------------------------------------------------------------------------------------------------------------------------------------------------------
# network manager
pacman -Sy networkmanager
systemctl enable NetworkManager
#------------------------------------------------------------------------------------------------------------------------------------------------------------------


#------------------------------------------------------------------------------------------------------------------------------------------------------------------
ln -sf /usr/share/zoneinfo/Europe/Istanbul /etc/localtime
hwclock --systohc

echo "ThisIsMyKingdomCOME" > /etc/hostname
useradd -m -G wheel -s /bin/bash archkubi
nano /etc/sudoers
passwd archkubi
passwd root
#------------------------------------------------------------------------------------------------------------------------------------------------------------------


#------------------------------------------------------------------------------------------------------------------------------------------------------------------
nano /etc/locale.conf
	# LANG=en_US.UTF-8
nano /etc/locale.gen
	find en_us and remove #
sudo nano /etc/vconsole.conf
	KEYMAP=us
locale-gen
#------------------------------------------------------------------------------------------------------------------------------------------------------------------

pacman -Sy qtile lxdm git xorg xorg-server xorg-apps xorg-xinit xterm xorg-xrdb xorg-xset
systemctl enable lxdm

pacman -S dkms broadcom-wl-dkms

pacman -Sy --noconfirm pipewire pipewire-alsa pipewire-jack wireplumber alsa-utils
systemctl enable --now pipewire pipewire-jack pipewire-alsa wireplumber

#------------------------------------------------------------------------------------------------------------------------------------------------------------------
# open source version
pacman -S   nvidia-open nvidia-open-dkms lib32-nvidia-utils lib32-opencl-nvidia nvidia-settings

#10XX driver for my GTX 1050TI
yay -Sy nvidia-580xx-dkms nvidia-580xx-settings nvidia-580xx-utils lib32-nvidia-580xx-utils lib32-opencl-nvidia-580xx opencl-nvidia-580xx

# amd new
pacman -S xf86-video-amdgpu mesa vulkan-radeon lib32-mesa lib32-vulkan-radeon

# amd old
pacman -S xf86-video-ati mesa

# intel
pacman -S xf86-video-intel mesa lib32-mesa lib32-vulkan-intel
#----------------------------
grub-install --target=i386-pc /dev/sda
grub-mkconfig -o /boot/grub/grub.cfg

reboot
