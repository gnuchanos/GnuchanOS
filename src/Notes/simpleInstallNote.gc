# add cachyos repo
curl https://mirror.cachyos.org/cachyos-repo.tar.xz -o cachyos-repo.tar.xz
tar xvf cachyos-repo.tar.xz && cd cachyos-repo
sudo ./cachyos-repo.sh
#------------------------------------------------------------------------------------------------------------------------------------------------------------------

# cachyos repo
pacman -Syu linux-cachyos linux-cachyos-headers linux-firmware

# default 
pacman -Syu linux linux-headers linux-firmware

# nvidia 
pacman -S linux-cachyos-nvidia nvidia-utils opencl-nvidia vulkan-icd-loader lib32-nvidia-utils lib32-opencl-nvidia  nvidia-settings
pacman -S linux-cachyos-nvidia-open nvidia-utils opencl-nvidia lib32-nvidia-utils lib32-opencl-nvidia nvidia-settings

# stupid artix iso
pacman -S nvidia nvidia-utils lib32-nvidia-utils opencl-nvidia vulkan-icd-loader nvidia-settings

# amd new
pacman -S xf86-video-amdgpu mesa vulkan-radeon lib32-mesa lib32-vulkan-radeon

# amd old
pacman -S xf86-video-ati mesa

# intel
pacman -S xf86-video-intel mesa lib32-mesa lib32-vulkan-intel


# extra
pacman -Sy qtile ly git xorg xorg-server xorg-apps xorg-xinit xterm xorg-xrdb xorg-xset
systemctl enable ly

# stupid artix iso
rc-update add ly default


# broadcom wifi
pacman -S dkms broadcom-wl-dkms


grub-install --target=i386-pc /dev/sda
grub-mkconfig -o /boot/grub/grub.cfg

reboot

# third part ---------------------------------------------------------------------------------------------------------------------------------------------------------------

# sound
sudo pacman -S pipewire pipewire-alsa pipewire-jack pipewire-pulse wireplumber
systemctl --user enable --now pipewire.service  wireplumber.service

# stupid artix iso
sudo pacman -S pavucontrol pulseaudio alsa-utils

