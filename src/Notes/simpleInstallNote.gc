# first part ---------------------------------------------------------------------------------------------------------------------------------------------------------------

parted /dev/sda mklabel msdos
cfdisk /dev/sda

# sda 1    - Swap
# sda 2    - Boot
# sda 3    - ALL Disk

# disk part
mkswap /dev/sda1
swapon /dev/sda1
mkfs.ext4 /dev/sda2
mkfs.ext4 /dev/sda3

# mount disk part
mount /dev/sda3 /mnt         # Mount root
mkdir /mnt/boot              # Create /boot directory
mount /dev/sda2 /mnt/boot    # Mount /boot

# last need
pacstrap /mnt base base base-devel grub
genfstab -U /mnt >> /mnt/etc/fstab
arch-chroot /mnt


# stupid artix iso
basestrap /mnt base base base-devel grub nano
fstabgen -U /mnt >> /mnt/etc/fstab
artix-chroot /mnt

pacman -Sy openrc elogind-openrc grub linux linux-firmware

# second part ---------------------------------------------------------------------------------------------------------------------------------------------------------------

#------------------------------------------------------------------------------------------------------------------------------------------------------------------
# network manager
pacman -Sy networkmanager
systemctl enable NetworkManager

# stupid artix iso
pacman -S networkmanager networkmanager-openrc
rc-update add NetworkManager default
rc-service NetworkManager start


