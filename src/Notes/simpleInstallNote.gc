# first part ---------------------------------------------------------------------------------------------------------------------------------------------------------------

parted /dev/sda mklabel msdos
cfdisk /dev/sda

# sda 1    - Swap
# sda 2    - Boot
# sda 3    - ALL Disk

# disk part
mkswap /dev/sda1
swapon /dev/sda1
mkfs.ext4 /dev/sda2
mkfs.ext4 /dev/sda3

# mount disk part
mount /dev/sda3 /mnt         # Mount root
mkdir /mnt/boot              # Create /boot directory
mount /dev/sda2 /mnt/boot    # Mount /boot

# last need
pacstrap /mnt base base base-devel grub nano
genfstab -U /mnt >> /mnt/etc/fstab
arch-chroot /mnt

# second part ---------------------------------------------------------------------------------------------------------------------------------------------------------------

#------------------------------------------------------------------------------------------------------------------------------------------------------------------
# network manager
pacman -Sy networkmanager
systemctl enable NetworkManager

# stupid artix iso
pacman -S networkmanager networkmanager-openrc
rc-update add NetworkManager default
rc-service NetworkManager start


#------------------------------------------------------------------------------------------------------------------------------------------------------------------

vpnbook + openvpn

#------------------------------------------------------------------------------------------------------------------------------------------------------------------
ln -sf /usr/share/zoneinfo/Europe/Istanbul /etc/localtime
hwclock --systohc

echo "ThisIsMyKingdomCOME" > /etc/hostname
useradd -m -G wheel -s /bin/bash archkubi
nano /etc/sudoers
passwd archkubi
passwd root
#------------------------------------------------------------------------------------------------------------------------------------------------------------------


#------------------------------------------------------------------------------------------------------------------------------------------------------------------
nano /etc/locale.conf
	# LANG=en_US.UTF-8
nano /etc/locale.gen
	find en_us and remove #
sudo nano /etc/vconsole.conf
	KEYMAP=us
locale-gen
#------------------------------------------------------------------------------------------------------------------------------------------------------------------

#------------------------------------------------------------------------------------------------------------------------------------------------------------------
# add cachyos repo
curl https://mirror.cachyos.org/cachyos-repo.tar.xz -o cachyos-repo.tar.xz
tar xvf cachyos-repo.tar.xz && cd cachyos-repo
sudo ./cachyos-repo.sh
#------------------------------------------------------------------------------------------------------------------------------------------------------------------

# cachyos repo
pacman -Syu linux-cachyos linux-cachyos-headers linux-firmware # use it if you get new gpu newer then 1050 ti

# open source version
pacman -S nvidia nvidia-utils nvidia-utils opencl-nvidia lib32-nvidia-utils lib32-opencl-nvidia nvidia-settings

#default nvidia
nvidia-580xx-open-dkms # 1050 ti
sudo pacman -S linux linux-headers linux-firmware nvidia nvidia-utils

# amd new
pacman -S xf86-video-amdgpu mesa vulkan-radeon lib32-mesa lib32-vulkan-radeon

# amd old
pacman -S xf86-video-ati mesa

# intel
pacman -S xf86-video-intel mesa lib32-mesa lib32-vulkan-intel

# extra
pacman -Sy qtile ly git xorg xorg-server xorg-apps xorg-xinit xterm xorg-xrdb xorg-xset
systemctl enable ly

# broadcom wifi
pacman -S dkms broadcom-wl-dkms

# sound
sudo pacman -S pipewire pipewire-alsa pipewire-jack pipewire-pulse wireplumber

# if not working
systemctl --user enable --now pipewire.service  wireplumber.service

# ekstra notes
pacman -Syu reflector rsync
reflector --latest 5 --sort rate --save /etc/pacman.d/mirrorlist

grub-install --target=i386-pc /dev/sda
grub-mkconfig -o /boot/grub/grub.cfg

reboot

# third part ---------------------------------------------------------------------------------------------------------------------------------------------------------------

# for flatpak apps
sudo ln -sf /run/systemd/resolve/resolv.conf /etc/resolv.conf

sudo resolvectl flush-caches
sudo systemctl restart systemd-resolved
resolvectl status


# ============================
# 1️⃣ systemd-resolved için Cloudflare ayarı
# ============================
sudo mkdir -p /etc/systemd/resolved.conf.d
sudo tee /etc/systemd/resolved.conf.d/cloudflare.conf > /dev/null <<EOF
[Resolve]
DNS=1.1.1.1 1.0.0.1
FallbackDNS=8.8.8.8 8.8.4.4
DNSOverTLS=yes
EOF

# ============================
# 2️⃣ systemd-resolved servisini yeniden başlat ve aktif et
# ============================
sudo systemctl restart systemd-resolved
sudo systemctl enable systemd-resolved

# ============================
# 3️⃣ /etc/resolv.conf'u systemd stub'a bağla
# ============================
sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf

# ============================
# 4️⃣ NetworkManager bağlantı adını öğren (DHCP DNS override önlemek için)
# ============================
nmcli con show
# Çıktıda NAME sütununu not al. Örn: "Wired connection 1"

# ============================
# 5️⃣ Bağlantı için Cloudflare DNS ayarla
# ============================
# Kendi bağlantı adını aşağıya yaz
# Örn: "Wired connection 1"
nmcli con mod "Wired connection 1" ipv4.ignore-auto-dns yes
nmcli con mod "Wired connection 1" ipv4.dns "1.1.1.1 1.0.0.1"
nmcli con up "Wired connection 1"

# ============================
# 6️⃣ Test et
# ============================
resolvectl status       # DNS durumunu kontrol et
dig @1.1.1.1 example.com # Cloudflare ile çözümleme testi
ping 1.1.1.1            # Cloudflare ulaşılabilirlik testi


